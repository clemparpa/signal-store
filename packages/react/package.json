{
  "name": "@fluch/signal-store-react",
  "version": "0.1.4",
  "description": "React Provider/useStore bindings for @fluch/signal-store (option B: scoped instances)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fluch/signal-store": "workspace:*"
  },
  "peerDependencies": {
    "@preact/signals-core": "^1.8.0",
    "@preact/signals-react": "^2.0.0",
    "react": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@preact/signals-core": "^1.8.0",
    "@preact/signals-react": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "happy-dom": "^20.9.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
